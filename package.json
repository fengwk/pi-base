{
  "name": "pi-base",
  "version": "0.1.0",
  "description": "Minimal Pi extension with hashline read/edit/write/search tools",
  "type": "module",
  "exports": {
    ".": "./index.ts"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "hashline"
  ],
  "license": "MIT",
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "files": [
    "index.ts",
    "src/",
    "prompts/",
    "DESIGN.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "diff": "^8.0.3",
    "xxhash-wasm": "^1.1.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "@sinclair/typebox": "^0.34.48",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "directories": {
    "doc": ".",
    "test": "tests"
  }
}
