#!/usr/bin/env python3
import os
import subprocess
import sys


def usage() -> None:
    print(
        """Usage:
  image-understanding-cli --prompt <text> --image <path-or-url>

Options:
  --prompt <text>   Describe what to analyze or extract.
  --image <path>    Local path or URL of the image.
  -h, --help              Show this help message.

Notes:
  Execute this file directly.
  Uses MINIMAX_API_KEY from the environment.
"""
    )


def run(cmd: list[str]) -> int:
    completed = subprocess.run(cmd)
    return completed.returncode


def main() -> int:
    args = sys.argv[1:]
    if not args or args[0] in {"-h", "--help", "help"}:
        usage()
        return 0

    prompt = None
    image = None
    i = 0
    while i < len(args):
        if args[i] == "--prompt":
            if i + 1 >= len(args):
                print("Missing value for --prompt", file=sys.stderr)
                return 2
            prompt = args[i + 1]
            i += 2
            continue
        if args[i] == "--image":
            if i + 1 >= len(args):
                print("Missing value for --image", file=sys.stderr)
                return 2
            image = args[i + 1]
            i += 2
            continue
        print(f"Unknown argument: {args[i]}", file=sys.stderr)
        usage()
        return 2

    if not prompt or not image:
        print("--prompt and --image are required", file=sys.stderr)
        usage()
        return 2

    normalized_image = image[1:] if image.startswith("@") else image
    api_key = os.environ.get("MINIMAX_API_KEY")
    if not api_key:
        print("MINIMAX_API_KEY is required", file=sys.stderr)
        return 2

    return run(
        [
            "mmx",
            "vision",
            "describe",
            "--image",
            normalized_image,
            "--prompt",
            prompt,
            "--output",
            "json",
        ]
    )


if __name__ == "__main__":
    raise SystemExit(main())
